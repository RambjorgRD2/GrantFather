# Supabase — get these from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Sentry — get DSN from sentry.io > Project > Settings > Client Keys
# Leave blank in local dev to disable Sentry (errors log to console instead)
VITE_SENTRY_DSN=

# Sentry source-map upload (CI / production builds only — never commit real values)
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug

# Required for Cypress E2E tests only (never expose in the browser)
# CYPRESS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
